{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "@webgpu/types",
            "vite/client",
            "node"
        ],
        "skipLibCheck": false
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "../dist"
    ]
}
