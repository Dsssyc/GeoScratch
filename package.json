{
  "name": "geoscratch",
  "version": "0.0.22",
  "description": "Tiny 3D library for geovisualization, powered by WebGPU",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./scratch": {
      "types": "./src/scratch.d.ts",
      "import": "./src/scratch.js"
    },
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "public/shaders",
    "public/icon",
    "public/images"
  ],
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "test": "mocha \"tests/**/*.test.js\"",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YcSoku/GeoScratch.git"
  },
  "keywords": [
    "WebGPU",
    "3D Library",
    "Geovisualization"
  ],
  "author": "YcSoku",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/YcSoku/GeoScratch/issues"
  },
  "homepage": "https://github.com/YcSoku/GeoScratch#readme",
  "dependencies": {
    "@mapbox/tilebelt": "^1.0.2",
    "@mapbox/vector-tile": "^1.3.1",
    "@webgpu/types": "^0.1.40",
    "axios": "^1.6.8",
    "d3-delaunay": "^6.0.4",
    "d3-voronoi": "^1.1.4",
    "earcut": "^2.2.4",
    "hammerjs": "^2.0.8",
    "pbf": "^3.2.1"
  },
  "devDependencies": {
    "chai": "^5.1.0",
    "mocha": "^10.3.0",
    "playwright": "^1.60.0",
    "vite": "^5.1.5"
  }
}
