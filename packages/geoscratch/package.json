{
  "name": "geoscratch",
  "version": "0.0.22",
  "description": "Tiny 3D library for geovisualization, powered by WebGPU",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scratch": {
      "types": "./dist/scratch.d.ts",
      "import": "./dist/scratch.js"
    },
    "./geo": {
      "types": "./dist/geo/index.d.ts",
      "import": "./dist/geo/index.js"
    },
    "./geometry": {
      "types": "./dist/geometry/index.d.ts",
      "import": "./dist/geometry/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "README_zh.md",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YcSoku/GeoScratch.git"
  },
  "keywords": [
    "WebGPU",
    "3D Library",
    "Geovisualization"
  ],
  "author": "YcSoku",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/YcSoku/GeoScratch/issues"
  },
  "homepage": "https://github.com/YcSoku/GeoScratch#readme",
  "dependencies": {
    "@webgpu/types": "^0.1.71"
  }
}
